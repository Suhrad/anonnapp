{
  "name": "web3-social-prediction-backend",
  "version": "1.0.0",
  "description": "Node.js + Express backend for Web3 social + prediction platform (Reddit + Polymarket)",
  "type": "module",
  "main": "src/server.js",
  "scripts": {
    "dev": "nodemon src/server.js",
    "start": "node src/server.js",
    "seed": "node scripts/seed.js",
    "test:api": "node scripts/test-api.js",
    "sync:markets": "node scripts/syncMarkets.js",
    "vercel-build": "echo 'Build complete - no build step required'",
    "test": "NODE_OPTIONS='--experimental-vm-modules' jest --runInBand --forceExit",
    "test:watch": "NODE_OPTIONS='--experimental-vm-modules' jest --watch --runInBand",
    "test:coverage": "NODE_OPTIONS='--experimental-vm-modules' jest --coverage --runInBand --forceExit",
    "test:unit": "NODE_OPTIONS='--experimental-vm-modules' jest tests/unit --forceExit",
    "test:integration": "NODE_OPTIONS='--experimental-vm-modules' jest tests/integration --forceExit",
    "test:ci": "NODE_OPTIONS='--experimental-vm-modules' jest --coverage --ci --runInBand --forceExit"
  },
  "keywords": [
    "web3",
    "social",
    "prediction-market",
    "express",
    "mongodb"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@solana/web3.js": "^1.98.4",
    "@supabase/supabase-js": "^2.100.1",
    "bcryptjs": "^2.4.3",
    "bs58": "^5.0.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "ethers": "^6.9.0",
    "express": "^4.18.2",
    "express-mongo-sanitize": "^2.2.0",
    "express-rate-limit": "^7.1.5",
    "express-validator": "^7.0.1",
    "helmet": "^7.1.0",
    "hpp": "^0.2.3",
    "joi": "^17.11.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.0.0",
    "morgan": "^1.10.0",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "tweetnacl": "^1.0.3",
    "uuid": "^13.0.0",
    "ws": "^8.17.1",
    "xss-clean": "^0.1.4"
  },
  "devDependencies": {
    "@jest/globals": "^29.7.0",
    "jest": "^29.7.0",
    "mongodb-memory-server": "^10.4.3",
    "nodemon": "^3.0.1",
    "supertest": "^7.2.2"
  }
}
